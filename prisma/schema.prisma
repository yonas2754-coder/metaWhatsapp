// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Zone {
  EAAZ
  CAAZ
  SAAZ
  NAAZ
  SWAAZ
  WAAZ
  NR_Mekele
  NWR_Bahirdar
  ER_Dire_Dawa
  CER_Harar
  CNR_D_Birhan
  WR_Nekempt
  SER_Adama
  SR_Hawassa
  SWR_Jimma
  CWR_Ambo
  EER_Jigiiga
  NEER_Semera
  NNWR_Gonder
  NER_Dessie
  SWWR_Gambela
  WWR_Assosa
  SSWR_Wolyta
  Bill_Section
  Enterprise_office
}

enum TaskClassification {
  TECHNICAL
  BILLING
  PROVISIONING
}

enum RequestType {
  FAULT
  NEW_SERVICE
  MODIFICATION
}

enum SpecificRequestType {
  BROADBAND_DOWN
  FIBER_CUT
  INVOICE_DISPUTE
  SPEED_UPGRADE
}

model Complaint {
  id                    String              @id @default(cuid())
  ticketNumber          String              @unique
  phone                 String
  serviceNumber         String
  tasksClassification   TaskClassification
  requestType           RequestType
  specificRequestType   SpecificRequestType
  zone                  Zone
  remarks               String
  status                String              @default("PENDING")
  createdAt             DateTime            @default(now())

  @@index([phone])
  @@index([ticketNumber])
}

model UserSession {
  phone                    String   @id
  step                     String   @default("IDLE") 
  // Step list: IDLE, AWAITING_SERVICE_NUM, AWAITING_CLASS, AWAITING_REQ_TYPE, AWAITING_SPECIFIC, AWAITING_ZONE, AWAITING_REMARKS
  tempServiceNumber        String?
  tempTasksClassification  String?
  tempRequestType          String?
  tempSpecificRequestType  String?
  tempZone                 String?
  updatedAt                DateTime @updatedAt

  @@index([phone])
}